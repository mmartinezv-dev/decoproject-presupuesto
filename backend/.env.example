# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=decoproject
DB_PASS=decoproject
DB_NAME=decoproject

# Admin Credentials (required; do not use example values in production)
AUTH_USER=
AUTH_PASS=

# JWT Configuration (values in seconds)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=900
JWT_REFRESH_EXPIRES=604800

# Sentry (optional — leave empty to disable)
SENTRY_DSN=

# Optional comma-separated origins for cross-origin development clients
CORS_ORIGINS=http://localhost:5173
