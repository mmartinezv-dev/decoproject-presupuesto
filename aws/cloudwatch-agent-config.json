{
  "agent": {
    "metrics_collection_interval": 60,
    "logfile": "/opt/aws/amazon-cloudwatch-agent/logs/amazon-cloudwatch-agent.log"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/decoproject/combined.log",
            "log_group_name": "/DecoProject/backend",
            "log_stream_name": "{instance_id}/combined",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/decoproject/error.log",
            "log_group_name": "/DecoProject/backend",
            "log_stream_name": "{instance_id}/error",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/decoproject/pm2-out.log",
            "log_group_name": "/DecoProject/pm2",
            "log_stream_name": "{instance_id}/stdout",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/decoproject/pm2-error.log",
            "log_group_name": "/DecoProject/pm2",
            "log_stream_name": "{instance_id}/stderr",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/nginx/decoproject-access.log",
            "log_group_name": "/DecoProject/nginx",
            "log_stream_name": "{instance_id}/access",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/nginx/error.log",
            "log_group_name": "/DecoProject/nginx",
            "log_stream_name": "{instance_id}/error",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
